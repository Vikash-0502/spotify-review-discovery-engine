# Reddit API — create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=review-discovery-engine/1.0 by your_reddit_username

# PostgreSQL (requires pgvector extension)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/review_discovery

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/app.log

# NLP models (Phase 4)
EMBEDDING_MODEL=all-MiniLM-L6-v2
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REQUESTS_PER_MINUTE=30
GROQ_REQUESTS_PER_DAY=1000
GROQ_TOKENS_PER_MINUTE=12000
GROQ_TOKENS_PER_DAY=100000

# Weekly pulse (Phase 6)
PULSE_REVIEW_CAP=1000
PULSE_THEME_LIMIT=3
PULSE_QUOTE_LIMIT=3
PULSE_ACTION_LIMIT=3
PULSE_MAX_WORDS=250
PULSE_MAX_RETRIES=1
PULSE_PROMPT_VERSION=v1
PULSE_SAMPLING_SEED=42
PULSE_DOCS_MCP_COMMAND=
PULSE_DOCS_TIMEOUT_SECONDS=30

# API server (Phase 5)
API_HOST=0.0.0.0
API_PORT=8000

# Tests (optional separate database)
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/review_discovery_test
